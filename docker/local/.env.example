# ============================================================
# unified-ui Local Development Environment
# ============================================================
# Copy to .env and adjust values as needed:
#   cp .env.example .env
# ============================================================

# ======================== Infrastructure =====================

# PostgreSQL
POSTGRES_USER=unifiedui
POSTGRES_PASSWORD=unifiedui_password
POSTGRES_DB=unifiedui

# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=admin

# Redis
REDIS_PASSWORD=admin

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin

# HashiCorp Vault
VAULT_TOKEN=admin

# N8N PostgreSQL (separate database)
N8N_POSTGRES_USER=n8n
N8N_POSTGRES_PASSWORD=n8n_password
N8N_POSTGRES_DB=n8n

# ======================== Service Keys =======================

# Service-to-Service Authentication Keys
# Generate with: openssl rand -hex 32
PLATFORM_TO_AGENT_SERVICE_KEY=local-dev-platform-to-agent-key
AGENT_TO_PLATFORM_SERVICE_KEY=local-dev-agent-to-platform-key
AGENT_TO_REACT_SERVICE_KEY=local-dev-agent-to-react-key

# Secret Encryption Key (for credential caching)
# Generate with: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=local-dev-encryption-key-32chars

# ======================== Zitadel (OIDC Identity Provider) ===
# Zitadel runs on http://localhost:8088
# Admin Console: http://localhost:8088/ui/console
# OIDC Discovery: http://localhost:8088/.well-known/openid-configuration

ZITADEL_DB_NAME=zitadel
ZITADEL_DB_USER=zitadel
ZITADEL_DB_PASSWORD=zitadel_password
ZITADEL_ADMIN_USERNAME=zitadel-admin@zitadel.localhost
ZITADEL_ADMIN_PASSWORD=ZitadelAdmin1!
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters

# OIDC Application (registered in Zitadel)
OIDC_ISSUER_URL=http://localhost:8088
OIDC_CLIENT_ID=<your-zitadel-client-id>
OIDC_JWKS_URL=http://unifiedui-identity:8080/oauth/v2/keys
OIDC_USERINFO_URL=http://unifiedui-identity:8080/oidc/v1/userinfo

# Zitadel Management API (for user/group search)
# Create a service user in Zitadel with Org User Manager role
# and generate a Personal Access Token (PAT)
OIDC_ZITADEL_MANAGEMENT_API_URL=http://unifiedui-identity:8080/management/v1
OIDC_ZITADEL_SERVICE_TOKEN=<your-zitadel-service-user-pat>

# ======================== LDAP (Testing) =====================
# OpenLDAP:      ldap://localhost:389
# phpLDAPadmin:  https://localhost:6443
# Admin DN:      cn=admin,dc=unifiedui,dc=local
# See docker/local/ldap/seed.ldif for sample users and groups.

LDAP_ORGANISATION=unifiedui
LDAP_DOMAIN=unifiedui.local
LDAP_ADMIN_PASSWORD=admin

# LDAP Service User (read-only, created by osixia LDAP_READONLY_USER)
LDAP_SVC_PASSWORD=SvcPlatform!2026x
LDAP_BIND_DN=cn=svc-platform,dc=unifiedui,dc=local
LDAP_BIND_PASSWORD=SvcPlatform!2026x
LDAP_BASE_DN=dc=unifiedui,dc=local
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
LDAP_JWT_SECRET=
LDAP_JWT_REFRESH_SECRET=

# ======================== Azure AD / MSAL ====================
# Required for authentication. Get from Azure App Registration.
# Leave defaults for local dev without Azure AD (signature verification disabled).

MSAL_CLIENT_ID=your-app-registration-client-id
MSAL_CLIENT_SECRET=your-app-registration-client-secret
MSAL_TENANT_ID=your-azure-ad-tenant-id
MSAL_AUTHORITY=https://login.microsoftonline.com/common
MSAL_API_SCOPE=api://your-client-id/access_as_user

# ======================== File Storage =======================

# File storage backend: "local" or "azureblob"
FILE_STORAGE_TYPE=local
# Local filesystem (when FILE_STORAGE_TYPE=local)
FILE_STORAGE_LOCAL_BASE_PATH=/path/to/your/files
# Azure Blob Storage (when FILE_STORAGE_TYPE=azureblob)
# FILE_STORAGE_AZURE_BLOB_ACCOUNT_URL=https://youraccount.blob.core.windows.net
# FILE_STORAGE_AZURE_BLOB_CONTAINER=unifiedui-files
# Max upload size in bytes (default: 25 MB)
FILE_STORAGE_MAX_FILE_SIZE_BYTES=26214400

# ======================== System Admin =======================
# Per-IdP system admin. Set the field matching your identity provider.
MSAL_SYSTEM_ADMIN_EMAIL=
LDAP_SYSTEM_ADMIN_USERNAME=
OIDC_ZITADEL_SYSTEM_ADMIN_USERNAME=

# ================ Sample REST API Agent ===================
# Azure OpenAI credentials for LangChain/LangGraph agents.
# Leave empty to use only the echo agent.

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# Sample agent auth credentials
SAMPLE_AGENT_API_KEY=default-api-key
SAMPLE_AGENT_BASIC_USER=admin
SAMPLE_AGENT_BASIC_PASS=password
